# ── ClawPilot Environment Configuration ───────────────────────
# Copy this to .env and fill in your values.

# Unique name for this ClawPilot agent (shown in Teams cards)
# Use a distinct name per machine/instance so replies route correctly.
AGENT_NAME=DevBox-1

# Port for the ClawPilot middleware server
PORT=3978

# Public URL — used for response links in cards AND as the base URL
# that Teams outgoing webhook calls back to (e.g. /api/outgoing-webhook)
# OPTIONAL: If not set, the server auto-provisions a devtunnel on startup.
# Only set this if you want to use your own tunnel/proxy instead.
# PUBLIC_URL=https://abc123.devtunnels.ms

# ── ClawPilot → Teams (outbound notifications) ───────────────
# Power Automate workflow that posts Adaptive Cards to the Teams channel.
TEAMS_WEBHOOK_URL=

# ── Teams → ClawPilot (inbound replies via outgoing webhook) ──
# Create in Teams: Team → Manage team → Apps → Create outgoing webhook
# Set callback URL to: https://<your-public-url>/api/outgoing-webhook
# Paste the HMAC security token here.
OUTGOING_WEBHOOK_SECRET=

# ── MCP Server ────────────────────────────────────────────────
# Override the middleware URL the MCP server connects to
# Only needed if running the server on a non-default port/host
# CLAWPILOT_SERVER_URL=http://localhost:3978
